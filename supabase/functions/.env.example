# Secrets das Edge Functions — NÃO commitar valores reais (.env* já está no .gitignore).
#
# LOCAL:
#   cp supabase/functions/.env.example supabase/functions/.env  (e preencha)
#   supabase functions serve generate-diet --env-file supabase/functions/.env
#
# PRODUÇÃO (após `supabase link --project-ref <REF>`):
#   supabase secrets set --env-file supabase/functions/.env
#   (ou um a um: supabase secrets set EDGE_SHARED_SECRET=... GEMINI_API_KEY=...)
#
# OBS: SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetados automaticamente
# pelo runtime — NÃO precisam ser setados aqui.

# Segredo compartilhado entre o trigger do banco e a função. Gere um valor
# aleatório forte, ex.: `openssl rand -hex 32`
EDGE_SHARED_SECRET=

# Chave da API do Gemini (a mesma usada pela plataforma).
GEMINI_API_KEY=
