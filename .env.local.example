# ─── Gemini (Google AI) ──────────────────────────────────────────
# Pegue em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── Supabase (preencher quando tiver o projeto) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Edge Function generate-diet (kickoff do botão "Gerar plano") ─
# Segredo compartilhado com a Edge Function (MESMO valor do `supabase secrets
# set EDGE_SHARED_SECRET`). A rota kickoff usa pra autenticar a chamada à Edge.
EDGE_SHARED_SECRET=
# (Opcional) Sobrescreve a URL da Edge. Em produção deixe vazio (deriva de
# NEXT_PUBLIC_SUPABASE_URL). Em teste local, aponte pro deno: http://localhost:8000
EDGE_GENERATE_DIET_URL=
